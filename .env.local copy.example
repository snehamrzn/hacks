# Optional: Esri API key for the polished dark-gray-vector basemap.
# Get a free dev key at https://developers.arcgis.com/
# If unset, the app falls back to a public Esri vector basemap (lower rate limits, still works).
NEXT_PUBLIC_ARCGIS_API_KEY=

# Required for the "why this feeder" copilot panel.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
